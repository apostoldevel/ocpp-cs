{
  "prefix": "/etc/cs/",
  "locale": "en_US.UTF-8",
  "log": {
    "level": "notice",
    "file": "/var/log/cs/error.log",
    "access": "/var/log/cs/access.log",
    "stream": "/var/log/cs/stream.log"
  },
  "daemon": {
    "enabled": false,
    "pid": "/run/cs.pid"
  },
  "process": {
    "master": true,
    "helper": false,
    "user": "",
    "group": ""
  },
  "workers": 1,
  "server": {
    "listen": "0.0.0.0",
    "port": 9220,
    "root": "www"
  },
  "module": {
    "CSService": {
      "enable": true
    },
    "ChargePoint": {
      "enable": true
    }
  },
  "webhook": {
    "enable": false,
    "url": "",
    "authorization": "Off",
    "username": "",
    "password": "",
    "token": ""
  },
  "api": {
    "auth": false
  },
  "postgres": {
    "connect": true,
    "notice": false,
    "timeout": 10,
    "worker": {
      "min": 5,
      "max": 10
    }
  }
}
