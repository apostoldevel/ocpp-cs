{
  "title": "GetReportRequest",
  "type": "object",
  "required": ["requestId"],
  "properties": {
    "requestId": {
      "type": "integer",
      "description": "Unique request ID"
    },
    "componentVariable": {
      "type": "array",
      "description": "Filter: specific components/variables to report",
      "items": {
        "type": "object",
        "properties": {
          "component": {
            "type": "object",
            "properties": {
              "name": { "type": "string" }
            }
          },
          "variable": {
            "type": "object",
            "properties": {
              "name": { "type": "string" }
            }
          }
        }
      }
    },
    "componentCriteria": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["Active", "Available", "Enabled", "Problem"]
      }
    }
  }
}
