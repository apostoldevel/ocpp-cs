{
    "$schema": "http://json-schema.org/draft-04/schema#",
    "title": "RequestStartTransactionRequest",
    "type": "object",
    "properties": {
        "evseId": {
            "type": "integer",
            "description": "EVSE ID (0 = auto-select)"
        },
        "idToken": {
            "type": "object",
            "properties": {
                "idToken": { "type": "string", "maxLength": 36 },
                "type": { "type": "string", "enum": ["Central", "eMAID", "ISO14443", "ISO15693", "KeyCode", "Local", "MacAddress", "NoAuthorization"] }
            },
            "required": ["idToken", "type"]
        }
    },
    "required": ["idToken"]
}
