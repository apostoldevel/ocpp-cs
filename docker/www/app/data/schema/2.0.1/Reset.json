{
    "$schema": "http://json-schema.org/draft-04/schema#",
    "title": "ResetRequest",
    "type": "object",
    "properties": {
        "type": {
            "type": "string",
            "enum": ["Immediate", "OnIdle"]
        },
        "evseId": {
            "type": "integer",
            "description": "Optional EVSE ID (omit for full reset)"
        }
    },
    "required": ["type"]
}
